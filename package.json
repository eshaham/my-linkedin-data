{
  "name": "my-linkedin-data",
  "version": "0.1.0",
  "private": true,
  "description": "Import LinkedIn data export into SQLite for querying via Claude Code + SQLite MCP",
  "type": "module",
  "scripts": {
    "build": "tsc -p .",
    "typecheck": "tsc -p . --noEmit",
    "import": "tsx src/scripts/import.ts",
    "import:profiles": "tsx src/scripts/import-profiles.ts",
    "enrich": "tsx src/scripts/enrich.ts",
    "search": "tsx src/scripts/search.ts",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:studio": "drizzle-kit studio",
    "format": "prettier --write .",
    "format:check": "prettier --check ."
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "better-sqlite3": "^11.3.0",
    "commander": "^14.0.3",
    "csv-parse": "^5.5.6",
    "dotenv": "^17.4.2",
    "drizzle-orm": "^0.45.2",
    "openai": "^6.39.0",
    "sqlite-vec": "^0.1.9"
  },
  "devDependencies": {
    "@trivago/prettier-plugin-sort-imports": "^6.0.2",
    "@types/better-sqlite3": "^7.6.11",
    "@types/node": "^22.7.4",
    "drizzle-kit": "^0.31.10",
    "prettier": "^3.8.3",
    "tsx": "^4.19.1",
    "typescript": "^5.6.2"
  }
}
